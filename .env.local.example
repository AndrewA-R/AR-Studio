# ── Sanity ────────────────────────────────────────────────
# Create at https://sanity.io/manage → New project. Copy the projectId here.
NEXT_PUBLIC_SANITY_PROJECT_ID=replace-me
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Read token (Sanity → API → Tokens → "Add API token", read-only).
# Used for draft preview + ISR. Optional for public reads.
SANITY_API_READ_TOKEN=

# ── Resend (contact form) ─────────────────────────────────
# https://resend.com → API Keys → Create. Verify domain a-r.studio first.
RESEND_API_KEY=
# Where the contact form emails go. Change anytime — no redeploy needed if set in Vercel.
CONTACT_TO_EMAIL=andrew@a-r.studio
CONTACT_FROM_EMAIL=hello@a-r.studio

# ── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.a-r.studio
